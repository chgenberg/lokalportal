generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  name             String
  role             String   @default("buyer") // "buyer" | "seller" | "admin" | "partner"
  isBuyer          Boolean  @default(false)
  isSeller         Boolean  @default(false)
  isAdmin          Boolean  @default(false)
  phone            String?
  logoUrl          String?
  companyName      String?
  stripeCustomerId String?  @unique
  bankIdVerified        Boolean  @default(false)
  bankIdPersonalNumber  String?
  subscriptionTier      String   @default("free") // "free" | "premium"
  subscriptionStripeId  String?  @unique
  subscriptionExpiresAt DateTime?
  createdAt        DateTime @default(now())

  listings              Listing[]
  agentListings         Listing[]      @relation("AgentListings")
  favorites             Favorite[]
  sellerConversations   Conversation[] @relation("SellerConversations")
  buyerConversations    Conversation[] @relation("BuyerConversations")
  messages              Message[]
  agentClients          AgentClient[]  @relation("AgentClients")
  clientOfAgents        AgentClient[]  @relation("ClientOfAgent")
  buyerProfiles         BuyerProfile[]
  budgetIntents         BudgetIntent[]
  matches               Match[]
  viewingBookings       ViewingBooking[]
  serviceOrders         ServiceOrder[]  @relation("UserServiceOrders")
  notifications         Notification[]

  @@map("users")
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  city        String
  address     String
  type        String   // "sale"
  category    String   // "villa" | "lagenhet" | "fritidshus" | "tomt"
  propertyType String  @default("lagenhet") // "villa" | "lagenhet" | "fritidshus" | "tomt"
  price       Int
  size        Int
  rooms       Int?
  lotSize     Int?
  condition   String?  // "nyskick" | "renoverat" | "bra_skick" | "renoveringsbehov"
  energyClass String?  // "A" | "B" | "C" | "D" | "E" | "F" | "G"
  yearBuilt   Int?
  monthlyFee  Int?
  acceptancePrice Int? // Seller's minimum acceptable price (hidden from buyers)
  status      String   @default("active") // "draft" | "active" | "paused" | "sold" | "removed"
  ownershipVerified Boolean @default(false)

  privacyLevel Json?  // { addressVisibility: "area"|"street"|"full", showFloorPlan: bool, maxPublicImages: int, documentsAfterContact: bool }

  imageUrl    String   @default("")
  imageUrls   String[] @default([])
  videoUrl    String?
  floorPlanImageUrl String?
  floorPlanDescription String?
  areaData    Json?
  featured    Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  lat         Float    @default(0)
  lng         Float    @default(0)
  tags        String[] @default([])

  contactName  String @default("")
  contactEmail String @default("")
  contactPhone String @default("")

  // Stripe subscription (for listing publication)
  stripeSubscriptionId String?  @unique
  stripeStatus         String   @default("free") // "free" | "active" | "past_due" | "canceled"
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  agentId String?
  agent   User?   @relation("AgentListings", fields: [agentId], references: [id], onDelete: SetNull)

  conversations   Conversation[]
  favorites       Favorite[]
  matches         Match[]
  budgetIntents   BudgetIntent[]
  viewingBookings ViewingBooking[]
  serviceOrders   ServiceOrder[]

  @@index([city])
  @@index([type])
  @@index([category])
  @@index([propertyType])
  @@index([status])
  @@index([featured])
  @@index([ownerId])
  @@index([price])
  @@index([size])
  @@index([rooms])
  @@index([createdAt])
  @@index([city, type])
  @@index([city, propertyType])
  @@index([city, category])
  @@index([type, category])
  @@index([city, type, price])
  @@index([ownerId, createdAt])
  @@index([stripeStatus])
  @@index([agentId])
  @@map("listings")
}

model Conversation {
  id            String   @id @default(uuid())
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User     @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User     @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  budgetMatched Boolean  @default(false)
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  messages Message[]

  @@unique([listingId, buyerId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  fileUrl      String?
  fileName     String?
  fileSize     Int?
  fileMimeType String?

  @@index([conversationId])
  @@index([senderId])
  @@index([read])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  source    String   @default("pdf-generator")
  createdAt DateTime @default(now())

  @@index([email])
  @@map("leads")
}

model Event {
  id        String   @id @default(uuid())
  type      String   // "view" | "inquiry" | "favorite" | "unfavorite" | "publish" | "contact_click" | "match"
  listingId String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([listingId, type, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
  @@map("events")
}

model AgentClient {
  id        String   @id @default(uuid())
  agentId   String
  agent     User     @relation("AgentClients", fields: [agentId], references: [id], onDelete: Cascade)
  clientId  String
  client    User     @relation("ClientOfAgent", fields: [clientId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([agentId, clientId])
  @@index([agentId])
  @@index([clientId])
  @@map("agent_clients")
}

model BuyerProfile {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Min sökning")
  active    Boolean  @default(true)

  areas         String[] @default([]) // Cities/areas of interest
  propertyTypes String[] @default([]) // "villa" | "lagenhet" | "fritidshus" | "tomt"
  minPrice      Int?
  maxPrice      Int?
  minSize       Int?
  maxSize       Int?
  minRooms      Int?
  maxRooms      Int?
  minLotSize    Int?
  maxLotSize    Int?
  condition     String[] @default([]) // Acceptable conditions
  features      String[] @default([]) // Special: "pool","sjotomt","garage","balkong", etc.

  notifyEmail   Boolean  @default(true)
  notifyPush    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]

  @@index([userId])
  @@index([active])
  @@map("buyer_profiles")
}

model BudgetIntent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  budget    Int      // Buyer's maximum budget
  matched   Boolean  @default(false) // True if budget >= acceptancePrice
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([matched])
  @@map("budget_intents")
}

model Match {
  id             String   @id @default(uuid())
  buyerProfileId String
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score          Float    @default(0) // Match quality 0-1
  seen           Boolean  @default(false)
  dismissed      Boolean  @default(false)
  notified       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([buyerProfileId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([seen])
  @@index([createdAt])
  @@map("matches")
}

model ViewingBooking {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "digital" | "physical"
  status    String   @default("pending") // "pending" | "confirmed" | "completed" | "canceled"
  scheduledAt DateTime
  videoLink   String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("viewing_bookings")
}

model ServiceOrder {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserServiceOrders", fields: [userId], references: [id], onDelete: Cascade)
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  type      String   // "photo" | "valuation" | "contract" | "inspection" | "energy_declaration" | "legal" | "moving"
  status    String   @default("pending") // "pending" | "in_progress" | "completed" | "canceled"
  price     Int?
  notes     String?
  metadata  Json?
  stripePaymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([type])
  @@index([status])
  @@map("service_orders")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "match" | "message" | "budget_match" | "viewing" | "status_update" | "system"
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@index([userId, read])
  @@map("notifications")
}
